---
import { getAllPortfolios } from "../../lib/portfolio";
import PortfolioCard from "../../components/PortfolioCard.astro";

import MainLayout from "../../layout/MainLayout.astro";

const portfolios = getAllPortfolios();

const breadcrumbs = [{ label: "Home", href: "/" }, { label: "Portfolio" }];
---

<MainLayout title="Portfolio - Through Indonesia" breadcrumbs={breadcrumbs}>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-1">
    {
      portfolios.map((item) => (
        <a href={`/portfolio/${item.slug}`}>
          <PortfolioCard title={item.title} image={item.thumbnail} />
        </a>
      ))
    }
  </div>
</MainLayout>
