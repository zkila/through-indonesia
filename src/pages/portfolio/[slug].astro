---
import MainLayout from "../../layout/MainLayout.astro";
import Gallery from "../../components/Gallery";

import { getPortfolio, getAllPortfolios } from "../../lib/portfolio";

export function getStaticPaths() {
  const portfolios = getAllPortfolios();

  return portfolios.map((portfolio) => ({
    params: {
      slug: portfolio.slug,
    },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  throw new Error("Missing portfolio slug");
}

const portfolio = getPortfolio(slug);

if (!portfolio) {
  return Astro.redirect("/404");
}

const breadcrumbs = [
  { label: "Home", href: "/" },
  { label: "Portfolio", href: "/portfolio" },
  { label: portfolio.title },
];
---

<MainLayout
  title={`${portfolio.title} - Through Indonesia`}
  breadcrumbs={breadcrumbs}
>
  <Gallery masonry={true} images={portfolio.images} client:visible />
</MainLayout>
