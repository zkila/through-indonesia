---
interface Props {
  workshopSlug: string;
  workshopTitle: string;
}

import Button from "../components/ui/Button.astro";

const { workshopSlug, workshopTitle } = Astro.props;
---

<form id="registration-form" class="flex flex-col gap-3">
  <label class="flex flex-col text-sm flex-1">
    Your name
    <input
      type="text"
      name="fullName"
      placeholder="Jane Doe"
      required
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>
  <label class="flex flex-col text-sm flex-1">
    Your email
    <input
      type="email"
      name="email"
      placeholder="you@example.com"
      required
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <label class="flex flex-col text-sm flex-1">
    Your phone number
    <input
      type="tel"
      name="phone"
      placeholder="123-456-7890"
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <label class="flex flex-col text-sm flex-1">
    Your country
    <input
      type="text"
      name="country"
      placeholder="United States"
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    />
  </label>

  <input type="hidden" name="workshopSlug" value={workshopSlug} />

  <input type="hidden" name="workshopTitle" value={workshopTitle} />

  <label class="flex flex-col text-sm flex-1">
    Additional notes
    <textarea
      name="notes"
      placeholder="Tell us more about your interests..."
      class="mt-4 p-2.5 border border-gray-300 rounded-md text-sm focus:outline-none focus:border-blue-500"
    ></textarea>
  </label>
  <div class="border-t border-accent/20 my-1"></div>
  <Button type="submit" variant="secondary">Register</Button>
</form>

<script>
  (() => {
    console.log("script loaded");

    const form = document.getElementById("registration-form");

    if (!(form instanceof HTMLFormElement)) {
      console.error("Form element not found.");
      return;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch("/api/register", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(data),
        });

        if (!response.ok) {
          console.error(await response.text());
          return;
        }

        const result = await response.json();

        console.log(result);

        if (response.ok) {
          alert("Registration submitted!");
          form.reset();
        } else {
          alert(result.error ?? "Registration failed.");
        }
      } catch (err) {
        console.error(err);
        alert("Unable to connect to the server.");
      }
    });
  })();
</script>
